# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# IMAP para leer correos de codigos.
# Puedes usar CODES_IMAP_* o, si prefieres reutilizar un setup previo, IMAP_*.
# La API de inbox tambien usa CODES_IMAP_MAILBOX y CODES_IMAP_MAX_MESSAGES.
CODES_IMAP_HOST=mail.example.com
CODES_IMAP_PORT=993
CODES_IMAP_USER=panel@example.com
CODES_IMAP_PASSWORD=replace-with-panel-password
CODES_IMAP_TLS=true
CODES_IMAP_MAILBOX=INBOX
CODES_IMAP_MAX_MESSAGES=50

# Fallback opcional si quieres reutilizar nombres genericos.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_TLS=true

# Fuente externa opcional Goatstream
GOATSTREAM_BASE_URL=https://provider.example.com
GOATSTREAM_USERNAME=
GOATSTREAM_PASSWORD=
GOATSTREAM_MAX_ITEMS=3

# Fuente externa opcional SDNetPanel
SDNETPANEL_BASE_URL=https://provider.example.com
SDNETPANEL_USERNAME=
SDNETPANEL_PASSWORD=
SDNETPANEL_MAX_ITEMS=3

# Varias cuentas SDNetPanel opcionales; si existe, tiene prioridad sobre USERNAME/PASSWORD.
# Ejemplo:
# SDNETPANEL_ACCOUNTS_JSON=[{"id":"lstreaming","name":"Lstreaming","baseUrl":"https://sdnetpanel.com","email":"lstreaming@gmail.com","password":"cambia-esto","maxItems":3}]
SDNETPANEL_ACCOUNTS_JSON=

# Fuente externa opcional Spotinet, solo Netflix.
SPOTINET_BASE_URL=https://www.spotinetshop.com
SPOTINET_BACKEND_URL=https://spotinet-backend-798163743367.us-central1.run.app
SPOTINET_USERNAME=
SPOTINET_PASSWORD=
SPOTINET_MAX_ITEMS=4
SPOTINET_SEARCH_TIMEOUT_MS=15000
SPOTINET_RETRY_WAIT_MS=1500

# Varias cuentas Spotinet opcionales; si existe, tiene prioridad sobre USERNAME/PASSWORD.
# Ejemplo:
# SPOTINET_ACCOUNTS_JSON=[{"id":"spotinet-main","name":"Spotinet","baseUrl":"https://www.spotinetshop.com","email":"usuario@example.com","password":"cambia-esto","maxItems":4}]
SPOTINET_ACCOUNTS_JSON=

# Fuente externa opcional Glowprem
GLOWPREM_BASE_URL=https://provider.example.com
GLOWPREM_USERNAME=
GLOWPREM_PASSWORD=
GLOWPREM_MAX_ITEMS=3
GLOWPREM_DISABLED=false

# Bridge local de Telegram para flujos especiales de Netflix.
# Puedes usar modo directo con TELEGRAM_SESSION_STRING o modo bridge con CODES_TELEGRAM_BRIDGE_URL.
# En Vercel se recomienda TELEGRAM_SESSION_STRING para no depender de ngrok/VPS.
CODES_TELEGRAM_BRIDGE_URL=http://127.0.0.1:8787
CODES_TELEGRAM_BRIDGE_SECRET=replace-with-a-long-random-secret
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_BRIDGE_BOT_USERNAME=@tutiendastore_bot
TELEGRAM_BRIDGE_HOST=127.0.0.1
TELEGRAM_BRIDGE_PORT=8787
TELEGRAM_BRIDGE_WAIT_MS=15000
TELEGRAM_BRIDGE_MENU_TIMEOUT_MS=15000
TELEGRAM_BRIDGE_POLL_MS=250
TELEGRAM_BRIDGE_POST_CLICK_SETTLE_MS=150
TELEGRAM_BRIDGE_FOLLOW_UP_TIMEOUT_MS=10000
TELEGRAM_BRIDGE_SESSION_FILE=.telegram-bridge-session
